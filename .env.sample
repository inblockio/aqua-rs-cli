# ── aqua-cli (main binary) ────────────────────────────────────────────────────

# Path to keys.json file (absolute or relative to .env directory)
keys_file=keys.json

# Alchemy API key - used for on-chain verification and as fallback for --witness-eth
# Get one at https://www.alchemy.com
alchemy_key=

# Ethereum network for ETH witnessing/signing: sepolia, holesky, or mainnet
aqua_network=sepolia

# Full RPC endpoint URL for --witness-eth (e.g. https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY)
# If empty, auto-built from alchemy_key + aqua_network above
# Set this directly for non-Alchemy providers (Infura, self-hosted, etc.)
# rpc_url=

# TSA URL for --witness-tsa (optional, defaults to http://timestamp.digicert.com)
# tsa_url=http://timestamp.digicert.com

# ── Twilio Verify (email/phone identity claims) ─────────────────────────────
# Required for --create-object with email or phone templates.
# Sign up at https://www.twilio.com and create a Verify Service:
#   Console:  https://console.twilio.com
#   Docs:     https://www.twilio.com/docs/verify/api
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── aqua-notary (notary binary) ──────────────────────────────────────────────

# Path to keys.json for the notary binary (overrides default ~/.aqua/keys.json)
# Resolution order: --key CLI arg > AQUA_KEYS env > ~/.aqua/keys.json
# AQUA_KEYS=

# GitHub personal access token for identity claim verification
# Resolution order: GITHUB_TOKEN env > ~/.aqua/github_token file
# GITHUB_TOKEN=
